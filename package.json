{
	"name": "mackie-dlzcreator",
	"version": "1.0.5",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"postinstall": "husky",
		"build": "rimraf dist && tsc -p tsconfig.build.json",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"package": "yarn build && companion-module-build",
		"lint:raw": "eslint",
		"lint": "yarn lint:raw .",
		"format": "prettier -w ."
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-mackie-dlzcreator.git"
	},
	"bugs": {
		"url": "https://github.com/bitfocus/companion-module-mackie-dlzcreator/issues"
	},
	"engines": {
		"node": "^22.20"
	},
	"dependencies": {
		"@companion-module/base": "~1.14.0",
		"socket.io-client": "^4.7.5"
	},
	"devDependencies": {
		"@companion-module/tools": "^2.2.0",
		"@types/node": "^22.10.0",
		"eslint": "^9.16.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.2.0",
		"prettier": "^3.4.0",
		"rimraf": "^6.0.1",
		"typescript": "~5.7.0",
		"typescript-eslint": "^8.16.0"
	},
	"resolutions": {
		"serialize-javascript": "^7.0.3"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"packageManager": "yarn@4.6.0"
}
